# Required — Apify token for Reddit scraping
# Get one at https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_your_token_here

# Optional — defaults to labrat011/reddit-scraper
# APIFY_ACTOR_ID=labrat011/reddit-scraper

# Optional — only required when AI features are enabled (see RADAR_AI_ENABLED below)
# OPENAI_API_KEY=sk-your-openai-key

# Optional — Upwork browser session file (default: ~/.creator-radar/upwork-session.json)
# UPWORK_SESSION_PATH=/path/to/upwork-session.json

# Optional — Upwork search queries (comma-separated). Overrides defaults when --query is omitted.
# RADAR_UPWORK_SEARCH_QUERIES=UGC,Content Creator,TikTok Creator

# Optional — Upwork search queries file (one query per line; # comments allowed)
# RADAR_UPWORK_QUERIES_FILE=/path/to/upwork-queries.txt

# Optional — Max jobs per Upwork search query (default: 20)
# RADAR_UPWORK_LIMIT_PER_QUERY=20

# Optional — SQLite database (default: ~/.creator-radar/opportunities.db)
# RADAR_DB_PATH=/path/to/opportunities.db

# Optional — Reddit subreddits for import/notify worker (comma-separated)
# RADAR_REDDIT_SUBREDDITS=UGCCreators,ugc

# Optional — platforms for node worker.js notify fetch (comma-separated)
# RADAR_NOTIFY_PLATFORMS=reddit,upwork

# Optional — master AI switch (default: off). Enables import scoring + Reddit A/B/C classification.
# Requires OPENAI_API_KEY when enabled.
# RADAR_AI_ENABLED=true

# Optional — override import scoring only (default: follows RADAR_AI_ENABLED)
# RADAR_AI_SCORING=true

# Optional — override Reddit classification only (default: follows RADAR_AI_ENABLED)
# RADAR_AI_CLASSIFICATION=true

# Render worker — Slack notifications (node worker.js)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Worker dedup store (local JSON file)
SEEN_OPPORTUNITIES_PATH=seen_opportunities.json

# Required on Render for cross-run dedup (cron filesystem is ephemeral)
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token
# SEEN_STORE_REDIS_KEY=creator-radar:seen
